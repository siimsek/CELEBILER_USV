    <!-- Waypoint marker gn6 REMOVED per user request -->

    <!-- ================================================ -->
    <!-- PARKUR 3: Hedef seçimi (kamikaze)                -->
    <!-- Kırmızı / Yeşil / Siyah hedef dubalar           -->
    <!-- ================================================ -->
    <include><uri>model://boundary_buoy_orange</uri><name>boundary_buoy_orange_81</name><pose>-5.0 28.5 0 0 0 0</pose></include>
    <include><uri>model://boundary_buoy_orange</uri><name>boundary_buoy_orange_82</name><pose>5.0 28.5 0 0 0 0</pose></include>
