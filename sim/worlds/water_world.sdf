    <include><uri>model://target_buoy_red</uri><name>target_buoy_red</name><pose>-3.0 29.8 0 0 0 0</pose></include>
    <include><uri>model://target_buoy_green</uri><name>target_buoy_green</name><pose>0.0 29.8 0 0 0 0</pose></include>
    <include><uri>model://target_buoy_black</uri><name>target_buoy_black</name><pose>3.0 29.8 0 0 0 0</pose></include>

    <include>
      <uri>model://usv_model</uri>
      <name>usv_model</name>
      <pose>0 0 0.16 0 0 1.5707963267948966</pose>
    </include>

  </world>
</sdf>
