SIM_ENV_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SIM_PROJECT_ROOT="$(cd "$SIM_ENV_DIR/../.." && pwd)"

export USV_SIM="1"
export CAM_SOURCE="sim"
export TARGET_CLASS="KIRMIZI_SANCAK"
export MISSION_INPUT_FORMAT="${MISSION_INPUT_FORMAT:-flat_ordered}"
export MISSION_ALLOW_STRUCTURED_LEGACY="${MISSION_ALLOW_STRUCTURED_LEGACY:-0}"
export MISSION_SPLIT_P2_COUNT="${MISSION_SPLIT_P2_COUNT:-1}"
export MISSION_SPLIT_P3_COUNT="${MISSION_SPLIT_P3_COUNT:-2}"

export USV_LOG_ROOT="$SIM_PROJECT_ROOT/logs"
export SIM_LOG_DIR="$SIM_PROJECT_ROOT/logs/simulation"
export LOG_DIR="$SIM_PROJECT_ROOT/logs/system"
export SIM_CONTROL_DIR="$SIM_PROJECT_ROOT/sim/control"
export SIM_ARTIFACT_DIR="$SIM_PROJECT_ROOT/sim/artifacts"
export CONTROL_DIR="$SIM_CONTROL_DIR"

export MISSION_FILE="${MISSION_FILE:-$SIM_PROJECT_ROOT/sim/configs/mission_parkour_all.json}"
export SIM_HOME="${SIM_HOME:--35.363262,149.165237,584,0}"
export SIM_SITL_FRAME="${SIM_SITL_FRAME:-motorboat-skid}"
export SIM_SPEEDUP="${SIM_SPEEDUP:-1}"
export SIM_GUI="${SIM_GUI:-auto}"
export SIM_GZ_WORLD_NAME="${SIM_GZ_WORLD_NAME:-water_world}"
export SIM_GZ_MODEL_NAME="${SIM_GZ_MODEL_NAME:-usv_model}"
export SIM_GZ_MODEL_Z="${SIM_GZ_MODEL_Z:-0.16}"
# Görev başlamadan önce (sistem yeni açıldığında): SITL/EKF oturana kadar Gazebo XY'yi dünya spawn'unda tut.
# 0 = hemen SITL NED kullan (eski davranış). run_sim_stack sim.env yükler; değer saniye.
export SIM_GZ_POSE_ARM_S="${SIM_GZ_POSE_ARM_S:-5}"
# water_world içindeki usv_model başlangıç konumu ile aynı olmalı (0,0 tipik)
export SIM_GZ_SPAWN_X="${SIM_GZ_SPAWN_X:-0}"
export SIM_GZ_SPAWN_Y="${SIM_GZ_SPAWN_Y:-0}"
# Pose köprüsü: düşük Hz = daha az SetEntityPose/GUI titremesi (10 önerilir)
# SetEntityPose hizi (Hz); cok yuksek deger servis birikmesi ve titremeye yol acabilir
export SIM_GZ_POSE_HZ="${SIM_GZ_POSE_HZ:-10}"
# ATTITUDE yaw → Gazebo için üstel yumuşatma (0–1; yüksek = daha çevik)
export SIM_GZ_ATTITUDE_ALPHA="${SIM_GZ_ATTITUDE_ALPHA:-0.35}"
# Motor calibration (skid steer kinematics): Left=normal, Right=normal (usv_main motor mix handles steering)
export SIM_GZ_LEFT_MOTOR_REVERSED="${SIM_GZ_LEFT_MOTOR_REVERSED:-0}"
export SIM_GZ_RIGHT_MOTOR_REVERSED="${SIM_GZ_RIGHT_MOTOR_REVERSED:-0}"
export IGN_GAZEBO_RESOURCE_PATH="$SIM_PROJECT_ROOT/sim/models${IGN_GAZEBO_RESOURCE_PATH:+:$IGN_GAZEBO_RESOURCE_PATH}"
export GZ_SIM_RESOURCE_PATH="$SIM_PROJECT_ROOT/sim/models${GZ_SIM_RESOURCE_PATH:+:$GZ_SIM_RESOURCE_PATH}"
export SDF_PATH="$SIM_PROJECT_ROOT/sim/models${SDF_PATH:+:$SDF_PATH}"

export ROS_HOME="$SIM_PROJECT_ROOT/sim/.ros"
export ROS_LOG_DIR="$SIM_PROJECT_ROOT/logs/simulation/ros2"
# ROS2 rclpy dosya loglarinin aninda diskte gorunmesi (debug)
export RCUTILS_LOGGING_BUFFERED_STREAM=0

if [ -f /opt/ros/humble/setup.bash ]; then
    _sim_env_had_nounset=0
    case $- in
        *u*)
            _sim_env_had_nounset=1
            set +u
            ;;
    esac
    source /opt/ros/humble/setup.bash
    if [ "$_sim_env_had_nounset" -eq 1 ]; then
        set -u
    fi
    unset _sim_env_had_nounset
fi
