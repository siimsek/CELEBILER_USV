<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="usv_model">
    <static>false</static>
    <pose>0 0 0.16 0 0 0</pose>

    <link name="base_link">
      <!-- SITL SetEntityPose yetkisi kaldirildi, fizik motoruna birakildi -->
      <gravity>true</gravity>
      <!-- Mass ve damping for stable motion on water -->
      <!-- FIX: Increased damping to reduce vibration, adjusted inertia for better stability -->
      <!-- m=18 kg; esdeger kutu ~ hull_collision 1.62 x 0.81 x 0.35 m, COM merkezde -->
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>18.0</mass>
        <inertia>
          <ixx>1.168</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>4.120</iyy>
          <iyz>0</iyz>
          <izz>4.921</izz>
        </inertia>
        <linear_damping>2.0</linear_damping>
        <angular_damping>1.0</angular_damping>
      </inertial>
      <!-- Basit tekne silueti: gergedan + guverte + konut; carpisma tek kutu. -->
      <!-- FIX: Fixed collision physics, better contact damping to reduce vibration -->
      <collision name="hull_collision">
        <pose>0 0 0.15 0 0 0</pose>
        <geometry>
          <box><size>1.62 0.81 0.35</size></box>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
          </friction>
          <contact>
            <ode>
              <soft_cfm>0.001</soft_cfm>
              <soft_erp>0.8</soft_erp>
              <max_vel>0.1</max_vel>
            </ode>
          </contact>
        </surface>
      </collision>

      <visual name="hull_bottom">
        <pose>0 0 0.12 0 0 0</pose>
        <geometry>
          <box><size>1.68 0.78 0.16</size></box>
        </geometry>
        <material>
          <ambient>0.92 0.93 0.95 1</ambient>
          <diffuse>0.94 0.95 0.97 1</diffuse>
          <specular>0.12 0.12 0.14 1</specular>
        </material>
      </visual>

      <visual name="deck">
        <pose>0 0 0.22 0 0 0</pose>
        <geometry>
          <box><size>1.45 0.72 0.08</size></box>
        </geometry>
        <material>
          <ambient>0.88 0.90 0.92 1</ambient>
          <diffuse>0.90 0.92 0.94 1</diffuse>
        </material>
      </visual>

      <visual name="stripe">
        <pose>0 0 0.26 0 0 0</pose>
        <geometry>
          <box><size>1.46 0.12 0.04</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.35 0.72 1</ambient>
          <diffuse>0.18 0.42 0.85 1</diffuse>
        </material>
      </visual>

      <visual name="bow">
        <pose>0.78 0 0.14 0 0 0</pose>
        <geometry>
          <box><size>0.32 0.55 0.14</size></box>
        </geometry>
        <material>
          <ambient>0.90 0.91 0.93 1</ambient>
          <diffuse>0.92 0.93 0.95 1</diffuse>
        </material>
      </visual>

      <visual name="cabin">
        <pose>0.22 0 0.34 0 0 0</pose>
        <geometry>
          <box><size>0.42 0.38 0.18</size></box>
        </geometry>
        <material>
          <ambient>0.82 0.84 0.88 1</ambient>
          <diffuse>0.85 0.87 0.91 1</diffuse>
        </material>
      </visual>

      <sensor name="camera_sensor" type="camera">
        <pose>0.65 0 0.50 0 0.12 0</pose>
        <camera>
          <horizontal_fov>1.5708</horizontal_fov>
          <image>
            <width>640</width>
            <height>360</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>50</far>
          </clip>
        </camera>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>false</visualize>
        <topic>/camera/image_raw</topic>
      </sensor>

      <sensor name="lidar_sensor" type="gpu_lidar">
        <pose>0.65 0 0.28 0 0 0</pose>
        <topic>/scan</topic>
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <visualize>false</visualize>
        <ray>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
              <samples>1</samples>
            </vertical>
          </scan>
          <range>
            <min>0.08</min>
            <max>20.0</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
      </sensor>
    </link>

    <!-- Motor left thruster (virtual joint for control) -->
    <link name="motor_left_link">
      <gravity>false</gravity>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <!-- Dummy collision to prevent ODE geometry crash -->
      <collision name="motor_left_collision">
        <geometry>
          <sphere><radius>0.01</radius></sphere>
        </geometry>
      </collision>
    </link>

    <!-- Motor right thruster (virtual joint for control) -->
    <link name="motor_right_link">
      <gravity>false</gravity>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <!-- Dummy collision to prevent ODE geometry crash -->
      <collision name="motor_right_collision">
        <geometry>
          <sphere><radius>0.01</radius></sphere>
        </geometry>
      </collision>
    </link>

    <!-- Left motor joint: for force application -->
    <joint name="motor_left_joint" type="revolute">
      <parent>base_link</parent>
      <child>motor_left_link</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
      <limit>
        <lower>-3.14159</lower>
        <upper>3.14159</upper>
        <effort>50</effort>
        <velocity>100</velocity>
      </limit>
    </joint>

    <!-- Right motor joint: for force application -->
    <joint name="motor_right_joint" type="revolute">
      <parent>base_link</parent>
      <child>motor_right_link</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
      <limit>
        <lower>-3.14159</lower>
        <upper>3.14159</upper>
        <effort>50</effort>
        <velocity>100</velocity>
      </limit>
    </joint>

    <!-- Odometry Publisher for JSON Backend -->
    <plugin filename="libignition-gazebo-odometry-publisher-system.so" name="ignition::gazebo::systems::OdometryPublisher">
      <odom_publish_frequency>100</odom_publish_frequency>
      <odom_frame>world</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_topic>/model/usv_model/odometry</odom_topic>
    </plugin>

    <plugin filename="libignition-gazebo-velocity-control-system.so" name="ignition::gazebo::systems::VelocityControl">
      <link_name>base_link</link_name>
      <topic>/cmd_vel</topic>
      <initial_linear>0 0 0</initial_linear>
      <initial_angular>0 0 0</initial_angular>
    </plugin>

  </model>
</sdf>
